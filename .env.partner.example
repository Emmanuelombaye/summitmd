# Partner API integration (own product storefront -> Peak enrollment handoff)
# Copy values into your local .env (or hosting env vars).

# Required
VITE_PARTNER_BRAND_SLUG=antidote-health

# Preferred production pattern:
# point to your own backend endpoint that calls Peak partner-api with X-Partner-Api-Key.
# Example backend route: /api/enroll-start
VITE_PARTNER_ENROLLMENT_ENDPOINT=

# Optional direct API fallback for local/dev only (do NOT expose in production frontend)
VITE_PARTNER_API_BASE=https://kvopgyhcjcniaocjozje.supabase.co/functions/v1/partner-api
VITE_PARTNER_API_KEY=

# Optional routing controls
VITE_PARTNER_PORTAL_ORIGIN=
VITE_PARTNER_RETURN_URL=

# Optional map from storefront product IDs -> Peak product UUIDs.
# Keep as JSON string.
# Example:
# {"weightloss_semaglutide":"11111111-1111-1111-1111-111111111111","travel":"22222222-2222-2222-2222-222222222222"}
VITE_PARTNER_PRODUCT_MAP_JSON={}
