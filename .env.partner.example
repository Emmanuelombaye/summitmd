# SummitMD ↔ Peak Health Partner API
# Copy to .env.local for local dev. Set same PARTNER_* vars in Vercel (server only for key).

# --- Server (Vercel + local Vite middleware) — NEVER expose in Vite VITE_* vars ---
PARTNER_API_KEY=
PARTNER_BRAND_SLUG=summit-md
PARTNER_API_URL=https://vzzmdbdvcofajgrjgajq.supabase.co/functions/v1/partner-api
PARTNER_PORTAL_ORIGIN=https://www.peak-health.io
PARTNER_RETURN_URL=https://summitmd.vercel.app/shop

# --- Frontend (safe for Vite build) ---
VITE_PARTNER_BRAND_SLUG=summit-md
VITE_PARTNER_ENROLLMENT_ENDPOINT=/api/enroll-start
VITE_PARTNER_API_BASE=https://vzzmdbdvcofajgrjgajq.supabase.co/functions/v1/partner-api
VITE_PARTNER_PORTAL_ORIGIN=https://www.peak-health.io
VITE_PARTNER_RETURN_URL=https://summitmd.vercel.app/shop

# Optional: map shop product id -> Peak product UUID
# VITE_PARTNER_PRODUCT_MAP_JSON={"weightloss_semaglutide":"<uuid>"}

# --- Legacy FHIR mock (patient dashboard demo) ---
VITE_API_URL=https://teladoc-peakhealth.vercel.app/fhir
VITE_API_ENV=sandbox
VITE_TENANT_ID=peakhealth-default
VITE_APP_NAME=SummitMD
